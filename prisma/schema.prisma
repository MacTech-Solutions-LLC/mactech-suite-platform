  medium
  high
  mission_critical
}

enum AppLifecycle {
  planned
  development
  staging
  production
  deprecated
  retired
}

enum AppVisibility {
  internal
  customer
  hybrid
}

enum HealthStatus {
  up
  degraded
  down
  unknown
}

enum RiskSeverity {
  info
  low
  medium
  high
  critical
}

enum RiskStatus {
  open
  acknowledged
  resolved
  ignored
}

enum RiskCategory {
  health_down
  degraded
  failed_deployment
  crashed_deployment
  failed_workflow
  production_behind_main
  stale_deployment
  security_sensitive_change
  database_change
  auth_change
  env_config_change
  webhook_failure
  missing_health_endpoint
  missing_build_info
  missing_repo_mapping
  missing_railway_mapping
  // Sprint 39: anonymous render of a tracked page returns 5xx OR
  // the Next.js "Application error" sentinel — catches the case
  // where /api/health is fine but actual pages throw at SSR.
  application_error
}

enum IntegrationProvider {
  github
  railway
  cloudflare
  clerk
  internal
}

enum GitProvider {
  github
}

// Workflow status normalised across providers. GitHub returns
// `queued | in_progress | completed | waiting | requested`. We collapse
// the rare ones into `queued` for display.
enum WorkflowStatus {
  queued
  in_progress
  completed
  unknown
}

// Workflow conclusion. Null while status != completed; on completion
// GitHub returns one of `success | failure | cancelled | skipped |
// timed_out | action_required | neutral | stale | startup_failure`.
enum WorkflowConclusion {
  success
  failure
  cancelled
  skipped
  timed_out
  action_required
  neutral
  stale
  startup_failure
}

// Railway deployment lifecycle. Mirrors Railway's status values
// verbatim — the `unknown` bucket covers any future status they add
// before we update the enum, so a Railway API change can't crash the
// Suite. `crashed` is a distinct outcome from `failed` in Railway's
// model: failed = build/deploy never came up; crashed = process came
// up and then exited.
enum DeploymentStatus {
  queued
  initializing
  building
  deploying
  success
  failed
  crashed
  removed
  restarting
  sleeping
  skipped
  unknown
}

// Production-vs-default-branch comparison outcome the Railway sync
// computes per service. Drives the production_behind_main rule when
// combined with the GitHub HEAD from Slice 2. Distinct from the
// Slice-2 `RepoSnapshot.commitsBehind` because Slice 3 looks at the
// deployment-level commit (what's actually live on Railway) vs the
// repo-level latest commit (what's in GitHub). Same comparison, two
// different perspectives — kept separate for audit clarity.
enum DeploymentDriftStatus {
  in_sync
  behind
  ahead
  diverged
  unknown
}

// What a CommitSummary represents. `daily` and `weekly` are
// scheduled rollups; `release` and `deployment` are tied to a single
// shipped artifact; `incident` is an after-action narrative; `manual`
// is anything an operator generated on demand.
enum CommitSummaryType {
  daily
  weekly
  release
  deployment
  incident
  manual
}

// Edge type on the app dependency graph. Drives the ecosystem map's
// edge styling + the risk evaluator's blast-radius calculation when
