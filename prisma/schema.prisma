// MacTech Identity Command Center — Prisma schema.
// Mixes the original tenancy primitives (Tenant / User / Membership /
// AuditEvent / Project / Document) with the command-center models
// (UserProfile, CustomerOrganization, AppRegistry, ProductEntitlement,
// OrgUserAccess, AuditLog, SecurityEvent, RoleTemplate). Existing tables
// remain so legacy callers keep working.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// LEGACY TENANCY (kept; consumed by lib/auth/adapter.ts + lib/db/withTenant.ts)
// ============================================================================

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Tenant {
  id         String   @id @default(cuid())
  externalId String?  @unique
  name       String
  slug       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]

  @@index([externalId])
  @@index([slug])
  @@index([isActive])
}

model User {
  id         String   @id @default(cuid())
  externalId String   @unique
  email      String   @unique
  name       String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]

  @@index([externalId])
  @@index([email])
  @@index([isActive])
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(VIEWER)
  isActive  Boolean        @default(true)
  joinedAt  DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      String   @default("draft")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  title     String
  content   String?
  status    String   @default("draft")
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ============================================================================
// IDENTITY COMMAND CENTER
// ============================================================================

enum PlatformRole {
  mactech_super_admin
  mactech_admin
  mactech_support
  mactech_auditor
  mactech_read_only
  // External C3PAO assessor invited for a short vault-access window. Has
  // permission to request a time-boxed IP allowlist grant for vault-001
  // via /auditor-access; sees nothing else of the admin surface.
  cui_auditor
  none
}

enum UserStatus {
  active
  suspended
  invited
}

enum CustomerType {
  dib
  prime
  subcontractor
  internal
  other
}

enum CustomerStatus {
  active
  onboarding
  suspended
  archived
}

enum SubscriptionTier {
  starter
  professional
  enterprise
  federal
}

enum CmmcLevel {
  level1
  level2
  unknown
}

enum CuiBoundaryType {
  none
  vault_only
  customer_managed
  hybrid
}

enum AppStatus {
  active
  disabled
  development
}

enum AppCategory {
  vault
  compliance
  evidence
  capture
  reporting
  training
  admin
  other
}

// ============================================================================
// COMMAND CENTER OPERATIONAL ENUMS
// ============================================================================

enum AppCriticality {
  low
  medium
  high
  mission_critical
}

enum AppLifecycle {
  planned
  development
  staging
  production
  deprecated
  retired
}

enum AppVisibility {
  internal
  customer
  hybrid
}

enum HealthStatus {
  up
  degraded
  down
  unknown
}

enum RiskSeverity {
  info
  low
  medium
  high
  critical
}

enum RiskStatus {
  open
  acknowledged
  resolved
  ignored
}

enum RiskCategory {
  health_down
  degraded
  failed_deployment
  crashed_deployment
  failed_workflow
  production_behind_main
  stale_deployment
  security_sensitive_change
  database_change
  auth_change
  env_config_change
  webhook_failure
  missing_health_endpoint
  missing_build_info
  missing_repo_mapping
  missing_railway_mapping
}

enum IntegrationProvider {
  github
  railway
  cloudflare
  clerk
  internal
}

enum GitProvider {
  github
}

// Workflow status normalised across providers. GitHub returns
// `queued | in_progress | completed | waiting | requested`. We collapse
// the rare ones into `queued` for display.
enum WorkflowStatus {
  queued
  in_progress
  completed
  unknown
}

// Workflow conclusion. Null while status != completed; on completion
// GitHub returns one of `success | failure | cancelled | skipped |
// timed_out | action_required | neutral | stale | startup_failure`.
enum WorkflowConclusion {
  success
  failure
  cancelled
  skipped
  timed_out
  action_required
  neutral
  stale
  startup_failure
}

enum EntitlementPlan {
  none
  trial
  starter
  professional
  enterprise
  custom
}

enum EntitlementStatus {
  active
  trialing
  expired
  suspended
}

enum AuditCategory {
  auth
  user
  org
  entitlement
  role
  security
  vault
  evidence
  boundary
  capture
  system
}

enum AuditSeverity {
  info
  warning
  critical
}

enum SecuritySeverity {
  low
  medium
  high
  critical
}

enum SecurityEventStatus {
  open
  investigating
  resolved
  ignored
}

enum RoleScope {
  platform
  customer_org
}

model UserProfile {
  id                    String       @id @default(cuid())
  clerkUserId           String       @unique
  email                 String       @unique
  firstName             String?
  lastName              String?
  imageUrl              String?
  isInternalMacTechUser Boolean      @default(false)
  platformRole          PlatformRole @default(none)
  status                UserStatus   @default(active)
  lastSeenAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  orgAccess OrgUserAccess[]
  auditLogs AuditLog[]      @relation("AuditActor")

  @@index([email])
  @@index([clerkUserId])
  @@index([platformRole])
  @@index([status])
  @@index([isInternalMacTechUser])
}

model CustomerOrganization {
  id                  String           @id @default(cuid())
  clerkOrgId          String?          @unique
  name                String
  slug                String           @unique
  legalName           String?
  domain              String?
  cageCode            String?
  uei                 String?
  duns                String?
  industry            String?
  customerType        CustomerType     @default(other)
  status              CustomerStatus   @default(onboarding)
  subscriptionTier    SubscriptionTier @default(starter)
  cmmcTargetLevel     CmmcLevel        @default(unknown)
  cuiBoundaryType     CuiBoundaryType  @default(none)
  primaryContactName  String?
  primaryContactEmail String?
  notes               String?
  maxMembers          Int?
  imageUrl            String?
  /// True when this is an internal MacTech operator org (e.g. "MacTech
  /// Solutions"). Internal orgs don't appear in customer-facing matrices
  /// and don't get gated by ProductEntitlement — internal users are
  /// granted access to every app via the isInternalMacTechUser flag on
  /// their UserProfile, regardless of org-level entitlements.
  isInternalMacTech   Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  entitlements         ProductEntitlement[]
  orgUserAccess        OrgUserAccess[]
  auditLogs            AuditLog[]
  securityEvents       SecurityEvent[]
  webhookSubscriptions WebhookSubscription[]

  @@index([clerkOrgId])
  @@index([slug])
  @@index([status])
  @@index([subscriptionTier])
  @@index([cmmcTargetLevel])
  @@index([customerType])
}

// AppRegistry is the canonical source of truth for every MacTech app.
// Suite is the product; Command Center is the flagship capability —
// the operational fields below let `/command-center` answer "which apps
// exist, where do they live, are they healthy, are they behind main".
model AppRegistry {
  id                 String      @id @default(cuid())
  appKey             String      @unique
  name               String
  description        String?
  baseUrl            String?
  status             AppStatus   @default(active)
  category           AppCategory @default(other)
  requiresOrgContext Boolean     @default(true)
  isInternalOnly     Boolean     @default(false)

  // ── Command Center operational metadata ──────────────────────────────
  // Slug used in URLs and join keys when appKey isn't url-safe enough.
  slug                    String?        @unique
  // Public-facing URL the customer hits. e.g. https://capture.mactechsolutionsllc.com
  publicUrl               String?
  // Admin/console URL inside the app, when distinct from publicUrl.
  adminUrl                String?
  // Health endpoint the Suite probes during reconciliation. /api/health convention.
  healthUrl               String?
  // Build-info endpoint exposing { service, commitSha, branch, ... } per the
  // standard documented in docs/COMMAND_CENTER.md.
  buildInfoUrl            String?
  docsUrl                 String?
  supportUrl              String?
  // Subdomain (e.g. "capture") + apex domain (e.g. "mactechsolutionsllc.com")
  // used by the Subdomains registry view.
  subdomain               String?
  apexDomain              String?
  criticality             AppCriticality @default(medium)
  lifecycle               AppLifecycle   @default(production)
  visibility              AppVisibility  @default(customer)
  ownerName               String?
  ownerEmail              String?
  // Repository linkage. Slice 2 hangs GitRepository / AppRepositoryLink off
  // these — for slice 1 we record raw fullName + branch so the seed can
  // populate them now and the GitRepository sync can backfill later.
  repoFullName            String?
  repoDefaultBranch       String?        @default("main")
  // Railway linkage. Same story — slice 3 promotes these into RailwayResource
  // rows; slice 1 keeps them flat so the page can show "this app maps to
  // <project>/<service>" the moment seed data lands.
  railwayProjectId        String?
  railwayServiceId        String?
  railwayEnvironmentId    String?
  railwayEnvironmentName  String?        @default("production")
  cloudflareZoneId        String?
  cloudflareHostname      String?
  // Free-form JSON describing which compliance domains this app touches
  // (e.g. {"cmmc": ["3.3.1", "3.3.2"], "iso27001": ["A.9.2.5"]}).
  complianceRelevanceJson Json?
  dependencyNotes         String?
  operationalNotes        String?
  lastObservedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entitlements      ProductEntitlement[]
  auditLogs         AuditLog[]
  healthSnapshots   HealthCheckSnapshot[]
  riskFlags         OperationalRiskFlag[]
  integrationEvents IntegrationEvent[]
  repoLinks         AppRepositoryLink[]

  @@index([appKey])
  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([criticality])
  @@index([lifecycle])
  @@index([repoFullName])
}

model ProductEntitlement {
  id                     String            @id @default(cuid())
  customerOrganizationId String
  appRegistryId          String
  enabled                Boolean           @default(false)
  plan                   EntitlementPlan   @default(none)
  maxUsers               Int?
  startsAt               DateTime?
  expiresAt              DateTime?
  status                 EntitlementStatus @default(active)
  configurationJson      Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  customerOrganization CustomerOrganization @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  app                  AppRegistry          @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)

  @@unique([customerOrganizationId, appRegistryId])
  @@index([customerOrganizationId])
  @@index([appRegistryId])
  @@index([status])
  @@index([enabled])
}

model OrgUserAccess {
  id                     String     @id @default(cuid())
  customerOrganizationId String
  userProfileId          String
  clerkMembershipId      String?
  role                   String
  permissionsJson        Json?
  status                 UserStatus @default(invited)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  customerOrganization CustomerOrganization @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  userProfile          UserProfile          @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([customerOrganizationId, userProfileId])
  @@index([customerOrganizationId])
  @@index([userProfileId])
  @@index([status])
  @@index([role])
}

model AuditLog {
  id                     String        @id @default(cuid())
  timestamp              DateTime      @default(now())
  actorClerkUserId       String?
  actorEmail             String?
  actorUserProfileId     String?
  customerOrganizationId String?
  appRegistryId          String?
  eventType              String
  eventCategory          AuditCategory
  severity               AuditSeverity @default(info)
  action                 String
  resourceType           String?
  resourceId             String?
  ipAddress              String?
  userAgent              String?
  requestId              String?
  metadataJson           Json?
  createdAt              DateTime      @default(now())

  actor                UserProfile?          @relation("AuditActor", fields: [actorUserProfileId], references: [id], onDelete: SetNull)
  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: SetNull)
  app                  AppRegistry?          @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([eventCategory])
  @@index([severity])
  @@index([eventType])
  @@index([customerOrganizationId])
  @@index([actorUserProfileId])
  @@index([actorClerkUserId])
  @@index([appRegistryId])
  @@index([customerOrganizationId, timestamp])
}

model SecurityEvent {
  id                     String              @id @default(cuid())
  timestamp              DateTime            @default(now())
  customerOrganizationId String?
  actorClerkUserId       String?
  eventType              String
  severity               SecuritySeverity    @default(low)
  sourceAppKey           String?
  description            String
  ipAddress              String?
  userAgent              String?
  metadataJson           Json?
  status                 SecurityEventStatus @default(open)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([severity])
  @@index([status])
  @@index([customerOrganizationId])
  @@index([sourceAppKey])
}

model RoleTemplate {
  id              String    @id @default(cuid())
  scope           RoleScope
  key             String
  name            String
  description     String?
  permissionsJson Json
  isSystemRole    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([scope, key])
  @@index([scope])
  @@index([isSystemRole])
}

// ============================================================================
// PUBLIC API ACCESS (sibling apps + integrations)
// ============================================================================

enum ApiKeyStatus {
  active
  revoked
}

enum ApiKeyScope {
  audit_ingest // POST /api/audit/ingest
  org_read // GET /api/v1/orgs/*
  user_access_read // GET /api/v1/users/*/access
  webhook_send // outbound webhook deliveries (server-internal use)
}

/// API key for sibling apps + integrations to talk to the central hub.
/// Keys are stored as SHA-256 hashes — the plaintext is shown ONCE at
/// creation time and never retrievable again. Scopes restrict which
/// endpoints a key can hit.
model ApiKey {
  id          String        @id @default(cuid())
  name        String
  keyHash     String        @unique
  keyPrefix   String // first 12 chars of plaintext, for display ("mts_a1b2c3d4..."")
  scopes      ApiKeyScope[]
  appKey      String? // optional: tag this key as belonging to a specific MacTech app
  description String?
  createdById String?
  status      ApiKeyStatus  @default(active)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([keyHash])
  @@index([status])
  @@index([appKey])
}

// ============================================================================
// OUTGOING WEBHOOKS (central → sibling apps on entitlement / org changes)
// ============================================================================

enum WebhookSubscriptionStatus {
  active
  paused
  disabled
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  abandoned
}

model WebhookSubscription {
  id                     String                    @id @default(cuid())
  customerOrganizationId String? // optional: scope to one org. NULL = subscribe to all orgs.
  appKey                 String? // optional: subscriber identification (the consuming app)
  name                   String
  url                    String
  /// HMAC signing secret. Stored plaintext (never re-shown after create — but
  /// admin UI shows the prefix). Sibling apps verify via X-MacTech-Signature.
  secret                 String
  events                 String[] // e.g. ["entitlement.enabled", "customer_org.suspended"]
  status                 WebhookSubscriptionStatus @default(active)
  lastSuccessAt          DateTime?
  lastFailureAt          DateTime?
  failureCount           Int                       @default(0)
  createdById            String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  deliveries           WebhookDelivery[]

  @@index([customerOrganizationId])
  @@index([appKey])
  @@index([status])
}

model WebhookDelivery {
  id               String                @id @default(cuid())
  subscriptionId   String
  eventId          String // matches AuditLog.id when the trigger was an audit-worthy event
  eventType        String
  status           WebhookDeliveryStatus @default(pending)
  attemptCount     Int                   @default(0)
  responseStatus   Int?
  responseBodyHead String? // first ~512 chars of the response, for debugging
  errorMessage     String?
  payloadJson      Json
  scheduledAt      DateTime              @default(now())
  deliveredAt      DateTime?
  nextAttemptAt    DateTime?

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([eventType])
  @@index([scheduledAt])
}

// ============================================================================
// COMMAND CENTER — operational telemetry
// ============================================================================

// One row per health probe. Drives /command-center's "is the ecosystem
// healthy right now" tile and feeds the risk evaluator.
model HealthCheckSnapshot {
  id               String       @id @default(cuid())
  appRegistryId    String
  url              String
  status           HealthStatus @default(unknown)
  statusCode       Int?
  latencyMs        Int?
  // First 512 chars of the response body so a flaky build-info JSON is
  // diagnosable without storing a full payload.
  responseBodyHead String?
  errorMessage     String?
  checkedAt        DateTime     @default(now())
  createdAt        DateTime     @default(now())

  app AppRegistry @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)

  @@index([appRegistryId, checkedAt(sort: Desc)])
  @@index([status])
  @@index([checkedAt(sort: Desc)])
}

// One row per derived operational risk. Created idempotently by the
// evaluator: while the underlying condition holds, we keep ONE open row;
// when the condition resolves, we set resolvedAt + status=resolved rather
// than deleting so the audit trail is intact.
model OperationalRiskFlag {
  id              String       @id @default(cuid())
  appRegistryId   String?
  // Slice 2 fills this in for repo-level risks (security_sensitive_change,
  // failed_workflow). Slice 1 only emits app-level risks.
  gitRepositoryId String?
  severity        RiskSeverity @default(medium)
  status          RiskStatus   @default(open)
  category        RiskCategory
  title           String
  description     String?
  detectedAt      DateTime     @default(now())
  resolvedAt      DateTime?
  acknowledgedAt  DateTime?
  acknowledgedBy  String? // email of the actor that acked it
  metadataJson    Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  app AppRegistry? @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  // Idempotency: at most one OPEN flag of a given (app, category) pair at
  // a time. The evaluator finds an existing row instead of stacking new
  // ones every reconciliation cycle.
  @@unique([appRegistryId, category, status], name: "idempotent_open_flag")
  @@index([severity])
  @@index([status])
  @@index([category])
  @@index([detectedAt(sort: Desc)])
}

// Thin event envelope for ANY external integration event we receive
// (slice 2: GitHub webhooks; slice 3: Railway webhooks). Slice 1 only
// emits 'internal' provider rows tagging reconciliation runs so the
// timeline still has something to show before the webhooks land.
model IntegrationEvent {
  id              String              @id @default(cuid())
  provider        IntegrationProvider
  eventType       String
  eventAction     String?
  resourceType    String?
  resourceId      String?
  appRegistryId   String?
  gitRepositoryId String?
  severity        RiskSeverity        @default(info)
  payloadJson     Json?
  receivedAt      DateTime            @default(now())
  processedAt     DateTime?
  createdAt       DateTime            @default(now())

  app AppRegistry? @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  @@index([provider, receivedAt(sort: Desc)])
  @@index([eventType])
  @@index([appRegistryId, receivedAt(sort: Desc)])
}

// ============================================================================
// COMMAND CENTER — Repository Intelligence (Slice 2)
// ============================================================================

// One row per GitHub repository the Suite tracks. Linked to one or more
// AppRegistry rows via AppRepositoryLink (some monorepos serve multiple
// apps). The Suite never stores the GitHub PAT here — that lives in
// env at lib/integrations/github/client.ts. AgentOps capabilities
// receive (repoId, branch, sha) inputs and never the token itself.
model GitRepository {
  id                    String      @id @default(cuid())
  owner                 String
  repo                  String
  fullName              String      @unique // "owner/repo"
  htmlUrl               String?
  defaultBranch         String      @default("main")
  visibility            String? // "public" | "private" | "internal"
  provider              GitProvider @default(github)
  installationId        String? // GitHub App installation id (slice 5+)
  active                Boolean     @default(true)
  // The latest HEAD sha we observed on the default branch — populated
  // by syncRepository(). Drives production_behind_main detection in
  // combination with the deployed sha from /api/build-info.
  latestHeadSha         String?
  latestHeadShortSha    String?
  latestHeadCommittedAt DateTime?
  // Counters refreshed each sync. Cheap to render on the repo table
  // without re-querying every commit row.
  recentCommitCount     Int         @default(0)
  recentWorkflowCount   Int         @default(0)
  lastSyncedAt          DateTime?
  lastSyncError         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appLinks     AppRepositoryLink[]
  commits      GitCommitEvent[]
  workflowRuns GitWorkflowRun[]

  @@index([owner])
  @@index([active])
  @@index([provider])
}

// Many-to-many between AppRegistry and GitRepository. Most apps map
// 1:1 to a repo; monorepos (e.g. WELCOMETOTHETRIBE/CMMC contains
// codex + tooling) need many:many. The link carries deployment hints
// (production branch differs from default, deployment branch differs
// from production, etc.) so production_behind_main can compare the
// right two SHAs.
model AppRepositoryLink {
  id               String   @id @default(cuid())
  appRegistryId    String
  gitRepositoryId  String
  // The branch whose HEAD represents "what should be in production".
  // Defaults to GitRepository.defaultBranch but can be overridden when
  // an app deploys from `release/*` instead of `main`.
  productionBranch String   @default("main")
  // The branch the deployment pipeline pulls from. Same as production
  // for trunk-based shops; different for environments that promote.
  deploymentBranch String   @default("main")
  // The "primary" repo for an app when it has multiple. The Slice 2
  // production-drift evaluator only checks the primary link.
  isPrimary        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  app  AppRegistry   @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)
  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  @@unique([appRegistryId, gitRepositoryId])
  @@index([appRegistryId])
  @@index([gitRepositoryId])
}

// One row per observed commit on a tracked branch. Inserted by both
// the periodic sync (listRecentCommits) and the GitHub push webhook —
// idempotency on (gitRepositoryId, sha) means doubled-up writes are
// no-ops, which is what AgentOps wants when re-running a plan.
model GitCommitEvent {
  id               String    @id @default(cuid())
  gitRepositoryId  String
  sha              String // 40-char SHA-1
  shortSha         String // first 7 chars; denormalised for display
  branch           String?
  authorName       String?
  authorEmail      String?
  authorLogin      String? // GitHub login when available
  message          String // first line + body; trimmed at insert
  htmlUrl          String?
  committedAt      DateTime?
  pushedAt         DateTime?
  filesChanged     Int       @default(0)
  additions        Int       @default(0)
  deletions        Int       @default(0)
  // List of file paths in this commit. Used by the
  // security_sensitive_change evaluator. JSON array of strings.
  changedFilesJson Json?
  // Risk flags the commit triggered (`auth_change`, `database_change`,
  // `security_sensitive_change`, …). JSON array of strings; the
  // evaluator opens OperationalRiskFlag rows from these.
  riskFlagsJson    Json?
  // Raw webhook payload (minus signature headers). Stored for
  // diagnostic + replay; secrets are redacted at write time by
  // lib/audit.ts redactMetadata.
  rawPayloadJson   Json?

  createdAt DateTime @default(now())

  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  // Idempotency. Per AgentOps discipline: re-running the same sync or
  // re-receiving the same webhook MUST NOT create duplicate rows.
  @@unique([gitRepositoryId, sha])
  @@index([gitRepositoryId, committedAt(sort: Desc)])
  @@index([authorEmail])
  @@index([branch])
  @@index([committedAt(sort: Desc)])
}

// One row per GitHub workflow run we've observed. Inserted by both
// the periodic sync (listWorkflowRuns) and the workflow_run webhook;
// idempotency is on githubRunId.
model GitWorkflowRun {
  id              String              @id @default(cuid())
  gitRepositoryId String
  githubRunId     BigInt              @unique
  name            String
  event           String // "push" | "pull_request" | "workflow_dispatch" | …
  branch          String?
  headSha         String
  status          WorkflowStatus      @default(unknown)
  conclusion      WorkflowConclusion?
  htmlUrl         String?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  rawPayloadJson  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  @@index([gitRepositoryId, startedAt(sort: Desc)])
  @@index([branch])
  @@index([status])
  @@index([conclusion])
}
