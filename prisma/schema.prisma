// MacTech Identity Command Center — Prisma schema.
// Mixes the original tenancy primitives (Tenant / User / Membership /
// AuditEvent / Project / Document) with the command-center models
// (UserProfile, CustomerOrganization, AppRegistry, ProductEntitlement,
// OrgUserAccess, AuditLog, SecurityEvent, RoleTemplate). Existing tables
// remain so legacy callers keep working.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// LEGACY TENANCY (kept; consumed by lib/auth/adapter.ts + lib/db/withTenant.ts)
// ============================================================================

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Tenant {
  id         String   @id @default(cuid())
  externalId String?  @unique
  name       String
  slug       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]

  @@index([externalId])
  @@index([slug])
  @@index([isActive])
}

model User {
  id         String   @id @default(cuid())
  externalId String   @unique
  email      String   @unique
  name       String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]

  @@index([externalId])
  @@index([email])
  @@index([isActive])
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(VIEWER)
  isActive  Boolean        @default(true)
  joinedAt  DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      String   @default("draft")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  title     String
  content   String?
  status    String   @default("draft")
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ============================================================================
// IDENTITY COMMAND CENTER
// ============================================================================

enum PlatformRole {
  mactech_super_admin
  mactech_admin
  mactech_support
  mactech_auditor
  mactech_read_only
  // External C3PAO assessor invited for a short vault-access window. Has
  // permission to request a time-boxed IP allowlist grant for vault-001
  // via /auditor-access; sees nothing else of the admin surface.
  cui_auditor
  none
}

enum UserStatus {
  active
  suspended
  invited
}

enum CustomerType {
  dib
  prime
  subcontractor
  internal
  other
}

enum CustomerStatus {
  active
  onboarding
  suspended
  archived
}

enum SubscriptionTier {
  starter
  professional
  enterprise
  federal
}

enum CmmcLevel {
  level1
  level2
  unknown
}

enum CuiBoundaryType {
  none
  vault_only
  customer_managed
  hybrid
}

enum AppStatus {
  active
  disabled
  development
}

enum AppCategory {
  vault
  compliance
  evidence
  capture
  reporting
  training
  admin
  other
}

// ============================================================================
// COMMAND CENTER OPERATIONAL ENUMS
// ============================================================================

enum AppCriticality {
  low
  medium
  high
  mission_critical
}

enum AppLifecycle {
  planned
  development
  staging
  production
  deprecated
  retired
}

enum AppVisibility {
  internal
  customer
  hybrid
}

enum HealthStatus {
  up
  degraded
  down
  unknown
}

enum RiskSeverity {
  info
  low
  medium
  high
  critical
}

enum RiskStatus {
  open
  acknowledged
  resolved
  ignored
}

enum RiskCategory {
  health_down
  degraded
  failed_deployment
  crashed_deployment
  failed_workflow
  production_behind_main
  stale_deployment
  security_sensitive_change
  database_change
  auth_change
  env_config_change
  webhook_failure
  missing_health_endpoint
  missing_build_info
  missing_repo_mapping
  missing_railway_mapping
}

enum IntegrationProvider {
  github
  railway
  cloudflare
  clerk
  internal
}

enum GitProvider {
  github
}

// Workflow status normalised across providers. GitHub returns
// `queued | in_progress | completed | waiting | requested`. We collapse
// the rare ones into `queued` for display.
enum WorkflowStatus {
  queued
  in_progress
  completed
  unknown
}

// Workflow conclusion. Null while status != completed; on completion
// GitHub returns one of `success | failure | cancelled | skipped |
// timed_out | action_required | neutral | stale | startup_failure`.
enum WorkflowConclusion {
  success
  failure
  cancelled
  skipped
  timed_out
  action_required
  neutral
  stale
  startup_failure
}

// Railway deployment lifecycle. Mirrors Railway's status values
// verbatim — the `unknown` bucket covers any future status they add
// before we update the enum, so a Railway API change can't crash the
// Suite. `crashed` is a distinct outcome from `failed` in Railway's
// model: failed = build/deploy never came up; crashed = process came
// up and then exited.
enum DeploymentStatus {
  queued
  initializing
  building
  deploying
  success
  failed
  crashed
  removed
  restarting
  sleeping
  skipped
  unknown
}

// Production-vs-default-branch comparison outcome the Railway sync
// computes per service. Drives the production_behind_main rule when
// combined with the GitHub HEAD from Slice 2. Distinct from the
// Slice-2 `RepoSnapshot.commitsBehind` because Slice 3 looks at the
// deployment-level commit (what's actually live on Railway) vs the
// repo-level latest commit (what's in GitHub). Same comparison, two
// different perspectives — kept separate for audit clarity.
enum DeploymentDriftStatus {
  in_sync
  behind
  ahead
  diverged
  unknown
}

// What a CommitSummary represents. `daily` and `weekly` are
// scheduled rollups; `release` and `deployment` are tied to a single
// shipped artifact; `incident` is an after-action narrative; `manual`
// is anything an operator generated on demand.
enum CommitSummaryType {
  daily
  weekly
  release
  deployment
  incident
  manual
}

// Edge type on the app dependency graph. Drives the ecosystem map's
// edge styling + the risk evaluator's blast-radius calculation when
// an upstream goes down.
enum AppDependencyType {
  api_calls
  auth_provider
  shared_database
  shared_domain
  shared_component
  content_source
  evidence_source
  training_source
  capture_source
  governance_source
  qms_source
  vault_source
  webhook_source
  other
}

enum EntitlementPlan {
  none
  trial
  starter
  professional
  enterprise
  custom
}

enum EntitlementStatus {
  active
  trialing
  expired
  suspended
}

enum AuditCategory {
  auth
  user
  org
  entitlement
  role
  security
  vault
  evidence
  boundary
  capture
  system
}

enum AuditSeverity {
  info
  warning
  critical
}

enum SecuritySeverity {
  low
  medium
  high
  critical
}

enum SecurityEventStatus {
  open
  investigating
  resolved
  ignored
}

enum RoleScope {
  platform
  customer_org
}

model UserProfile {
  id                    String       @id @default(cuid())
  clerkUserId           String       @unique
  email                 String       @unique
  firstName             String?
  lastName              String?
  imageUrl              String?
  isInternalMacTechUser Boolean      @default(false)
  platformRole          PlatformRole @default(none)
  status                UserStatus   @default(active)
  lastSeenAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  orgAccess OrgUserAccess[]
  auditLogs AuditLog[]      @relation("AuditActor")

  @@index([email])
  @@index([clerkUserId])
  @@index([platformRole])
  @@index([status])
  @@index([isInternalMacTechUser])
}

model CustomerOrganization {
  id                  String           @id @default(cuid())
  clerkOrgId          String?          @unique
  name                String
  slug                String           @unique
  legalName           String?
  domain              String?
  cageCode            String?
  uei                 String?
  duns                String?
  industry            String?
  customerType        CustomerType     @default(other)
  status              CustomerStatus   @default(onboarding)
  subscriptionTier    SubscriptionTier @default(starter)
  cmmcTargetLevel     CmmcLevel        @default(unknown)
  cuiBoundaryType     CuiBoundaryType  @default(none)
  primaryContactName  String?
  primaryContactEmail String?
  notes               String?
  maxMembers          Int?
  imageUrl            String?
  /// True when this is an internal MacTech operator org (e.g. "MacTech
  /// Solutions"). Internal orgs don't appear in customer-facing matrices
  /// and don't get gated by ProductEntitlement — internal users are
  /// granted access to every app via the isInternalMacTechUser flag on
  /// their UserProfile, regardless of org-level entitlements.
  isInternalMacTech   Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  entitlements         ProductEntitlement[]
  orgUserAccess        OrgUserAccess[]
  auditLogs            AuditLog[]
  securityEvents       SecurityEvent[]
  webhookSubscriptions WebhookSubscription[]

  @@index([clerkOrgId])
  @@index([slug])
  @@index([status])
  @@index([subscriptionTier])
  @@index([cmmcTargetLevel])
  @@index([customerType])
}

// AppRegistry is the canonical source of truth for every MacTech app.
// Suite is the product; Command Center is the flagship capability —
// the operational fields below let `/command-center` answer "which apps
// exist, where do they live, are they healthy, are they behind main".
model AppRegistry {
  id                 String      @id @default(cuid())
  appKey             String      @unique
  name               String
  description        String?
  baseUrl            String?
  status             AppStatus   @default(active)
  category           AppCategory @default(other)
  requiresOrgContext Boolean     @default(true)
  isInternalOnly     Boolean     @default(false)

  // ── Command Center operational metadata ──────────────────────────────
  // Slug used in URLs and join keys when appKey isn't url-safe enough.
  slug                    String?        @unique
  // Public-facing URL the customer hits. e.g. https://capture.mactechsolutionsllc.com
  publicUrl               String?
  // Admin/console URL inside the app, when distinct from publicUrl.
  adminUrl                String?
  // Health endpoint the Suite probes during reconciliation. /api/health convention.
  healthUrl               String?
  // Build-info endpoint exposing { service, commitSha, branch, ... } per the
  // standard documented in docs/COMMAND_CENTER.md.
  buildInfoUrl            String?
  docsUrl                 String?
  supportUrl              String?
  // Subdomain (e.g. "capture") + apex domain (e.g. "mactechsolutionsllc.com")
  // used by the Subdomains registry view.
  subdomain               String?
  apexDomain              String?
  criticality             AppCriticality @default(medium)
  lifecycle               AppLifecycle   @default(production)
  visibility              AppVisibility  @default(customer)
  ownerName               String?
  ownerEmail              String?
  // Repository linkage. Slice 2 hangs GitRepository / AppRepositoryLink off
  // these — for slice 1 we record raw fullName + branch so the seed can
  // populate them now and the GitRepository sync can backfill later.
  repoFullName            String?
  repoDefaultBranch       String?        @default("main")
  // Railway linkage. Same story — slice 3 promotes these into RailwayResource
  // rows; slice 1 keeps them flat so the page can show "this app maps to
  // <project>/<service>" the moment seed data lands.
  railwayProjectId        String?
  railwayServiceId        String?
  railwayEnvironmentId    String?
  railwayEnvironmentName  String?        @default("production")
  cloudflareZoneId        String?
  cloudflareHostname      String?
  // Free-form JSON describing which compliance domains this app touches
  // (e.g. {"cmmc": ["3.3.1", "3.3.2"], "iso27001": ["A.9.2.5"]}).
  complianceRelevanceJson Json?
  dependencyNotes         String?
  operationalNotes        String?
  lastObservedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entitlements         ProductEntitlement[]
  auditLogs            AuditLog[]
  healthSnapshots      HealthCheckSnapshot[]
  riskFlags            OperationalRiskFlag[]
  integrationEvents    IntegrationEvent[]
  repoLinks            AppRepositoryLink[]
  railwayResources     RailwayResource[]
  deploymentSnapshots  DeploymentSnapshot[]
  commitSummaries      CommitSummary[]
  outgoingDependencies AppDependency[]       @relation("DependencySource")
  incomingDependencies AppDependency[]       @relation("DependencyTarget")
  outgoingCalls        AppCallEvent[]        @relation("CallEventSource")
  incomingCalls        AppCallEvent[]        @relation("CallEventTarget")

  @@index([appKey])
  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([criticality])
  @@index([lifecycle])
  @@index([repoFullName])
}

model ProductEntitlement {
  id                     String            @id @default(cuid())
  customerOrganizationId String
  appRegistryId          String
  enabled                Boolean           @default(false)
  plan                   EntitlementPlan   @default(none)
  maxUsers               Int?
  startsAt               DateTime?
  expiresAt              DateTime?
  status                 EntitlementStatus @default(active)
  configurationJson      Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  customerOrganization CustomerOrganization @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  app                  AppRegistry          @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)

  @@unique([customerOrganizationId, appRegistryId])
  @@index([customerOrganizationId])
  @@index([appRegistryId])
  @@index([status])
  @@index([enabled])
}

model OrgUserAccess {
  id                     String     @id @default(cuid())
  customerOrganizationId String
  userProfileId          String
  clerkMembershipId      String?
  role                   String
  permissionsJson        Json?
  status                 UserStatus @default(invited)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  customerOrganization CustomerOrganization @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  userProfile          UserProfile          @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([customerOrganizationId, userProfileId])
  @@index([customerOrganizationId])
  @@index([userProfileId])
  @@index([status])
  @@index([role])
}

model AuditLog {
  id                     String        @id @default(cuid())
  timestamp              DateTime      @default(now())
  actorClerkUserId       String?
  actorEmail             String?
  actorUserProfileId     String?
  customerOrganizationId String?
  appRegistryId          String?
  eventType              String
  eventCategory          AuditCategory
  severity               AuditSeverity @default(info)
  action                 String
  resourceType           String?
  resourceId             String?
  ipAddress              String?
  userAgent              String?
  requestId              String?
  metadataJson           Json?
  createdAt              DateTime      @default(now())

  actor                UserProfile?          @relation("AuditActor", fields: [actorUserProfileId], references: [id], onDelete: SetNull)
  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: SetNull)
  app                  AppRegistry?          @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([eventCategory])
  @@index([severity])
  @@index([eventType])
  @@index([customerOrganizationId])
  @@index([actorUserProfileId])
  @@index([actorClerkUserId])
  @@index([appRegistryId])
  @@index([customerOrganizationId, timestamp])
}

model SecurityEvent {
  id                     String              @id @default(cuid())
  timestamp              DateTime            @default(now())
  customerOrganizationId String?
  actorClerkUserId       String?
  eventType              String
  severity               SecuritySeverity    @default(low)
  sourceAppKey           String?
  description            String
  ipAddress              String?
  userAgent              String?
  metadataJson           Json?
  status                 SecurityEventStatus @default(open)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([severity])
  @@index([status])
  @@index([customerOrganizationId])
  @@index([sourceAppKey])
}

model RoleTemplate {
  id              String    @id @default(cuid())
  scope           RoleScope
  key             String
  name            String
  description     String?
  permissionsJson Json
  isSystemRole    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([scope, key])
  @@index([scope])
  @@index([isSystemRole])
}

// ============================================================================
// PUBLIC API ACCESS (sibling apps + integrations)
// ============================================================================

enum ApiKeyStatus {
  active
  revoked
}

enum ApiKeyScope {
  audit_ingest // POST /api/audit/ingest
  org_read // GET /api/v1/orgs/*
  user_access_read // GET /api/v1/users/*/access
  webhook_send // outbound webhook deliveries (server-internal use)
  /// Slice 5.7: external Claude / automation trigger for AgentOps runs.
  /// Holders may POST /api/v1/agents/runs with an Intent payload. The
  /// IBE gates do the heavy safety work — read-only-only plans
  /// auto-execute; plans containing any approval_required step land in
  /// awaiting_approval and can only be approved via the browser by a
  /// human admin (separation of duties is preserved because the M2M
  /// "requester" is a synthetic api-key:<id> identity, never matching a
  /// Clerk admin id).
  agents_trigger
}

/// API key for sibling apps + integrations to talk to the central hub.
/// Keys are stored as SHA-256 hashes — the plaintext is shown ONCE at
/// creation time and never retrievable again. Scopes restrict which
/// endpoints a key can hit.
model ApiKey {
  id          String        @id @default(cuid())
  name        String
  keyHash     String        @unique
  keyPrefix   String // first 12 chars of plaintext, for display ("mts_a1b2c3d4..."")
  scopes      ApiKeyScope[]
  appKey      String? // optional: tag this key as belonging to a specific MacTech app
  description String?
  createdById String?
  status      ApiKeyStatus  @default(active)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([keyHash])
  @@index([status])
  @@index([appKey])
}

// ============================================================================
// OUTGOING WEBHOOKS (central → sibling apps on entitlement / org changes)
// ============================================================================

enum WebhookSubscriptionStatus {
  active
  paused
  disabled
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  abandoned
}

model WebhookSubscription {
  id                     String                    @id @default(cuid())
  customerOrganizationId String? // optional: scope to one org. NULL = subscribe to all orgs.
  appKey                 String? // optional: subscriber identification (the consuming app)
  name                   String
  url                    String
  /// HMAC signing secret. Stored plaintext (never re-shown after create — but
  /// admin UI shows the prefix). Sibling apps verify via X-MacTech-Signature.
  secret                 String
  events                 String[] // e.g. ["entitlement.enabled", "customer_org.suspended"]
  status                 WebhookSubscriptionStatus @default(active)
  lastSuccessAt          DateTime?
  lastFailureAt          DateTime?
  failureCount           Int                       @default(0)
  createdById            String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  customerOrganization CustomerOrganization? @relation(fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  deliveries           WebhookDelivery[]

  @@index([customerOrganizationId])
  @@index([appKey])
  @@index([status])
}

model WebhookDelivery {
  id               String                @id @default(cuid())
  subscriptionId   String
  eventId          String // matches AuditLog.id when the trigger was an audit-worthy event
  eventType        String
  status           WebhookDeliveryStatus @default(pending)
  attemptCount     Int                   @default(0)
  responseStatus   Int?
  responseBodyHead String? // first ~512 chars of the response, for debugging
  errorMessage     String?
  payloadJson      Json
  scheduledAt      DateTime              @default(now())
  deliveredAt      DateTime?
  nextAttemptAt    DateTime?

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([eventType])
  @@index([scheduledAt])
}

// ============================================================================
// COMMAND CENTER — operational telemetry
// ============================================================================

// One row per health probe. Drives /command-center's "is the ecosystem
// healthy right now" tile and feeds the risk evaluator.
model HealthCheckSnapshot {
  id               String       @id @default(cuid())
  appRegistryId    String
  url              String
  status           HealthStatus @default(unknown)
  statusCode       Int?
  latencyMs        Int?
  // First 512 chars of the response body so a flaky build-info JSON is
  // diagnosable without storing a full payload.
  responseBodyHead String?
  errorMessage     String?
  checkedAt        DateTime     @default(now())
  createdAt        DateTime     @default(now())

  app AppRegistry @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)

  @@index([appRegistryId, checkedAt(sort: Desc)])
  @@index([status])
  @@index([checkedAt(sort: Desc)])
}

// One row per derived operational risk. Created idempotently by the
// evaluator: while the underlying condition holds, we keep ONE open row;
// when the condition resolves, we set resolvedAt + status=resolved rather
// than deleting so the audit trail is intact.
model OperationalRiskFlag {
  id              String       @id @default(cuid())
  appRegistryId   String?
  // Slice 2 fills this in for repo-level risks (security_sensitive_change,
  // failed_workflow). Slice 1 only emits app-level risks.
  gitRepositoryId String?
  severity        RiskSeverity @default(medium)
  status          RiskStatus   @default(open)
  category        RiskCategory
  title           String
  description     String?
  detectedAt      DateTime     @default(now())
  resolvedAt      DateTime?
  acknowledgedAt  DateTime?
  acknowledgedBy  String? // email of the actor that acked it
  metadataJson    Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  app AppRegistry? @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  // Idempotency: at most one OPEN flag of a given (app, category) pair at
  // a time. The evaluator finds an existing row instead of stacking new
  // ones every reconciliation cycle.
  @@unique([appRegistryId, category, status], name: "idempotent_open_flag")
  @@index([severity])
  @@index([status])
  @@index([category])
  @@index([detectedAt(sort: Desc)])
}

// Thin event envelope for ANY external integration event we receive
// (slice 2: GitHub webhooks; slice 3: Railway webhooks). Slice 1 only
// emits 'internal' provider rows tagging reconciliation runs so the
// timeline still has something to show before the webhooks land.
model IntegrationEvent {
  id              String              @id @default(cuid())
  provider        IntegrationProvider
  eventType       String
  eventAction     String?
  resourceType    String?
  resourceId      String?
  appRegistryId   String?
  gitRepositoryId String?
  severity        RiskSeverity        @default(info)
  payloadJson     Json?
  receivedAt      DateTime            @default(now())
  processedAt     DateTime?
  createdAt       DateTime            @default(now())

  app AppRegistry? @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  @@index([provider, receivedAt(sort: Desc)])
  @@index([eventType])
  @@index([appRegistryId, receivedAt(sort: Desc)])
}

// ============================================================================
// COMMAND CENTER — Repository Intelligence (Slice 2)
// ============================================================================

// One row per GitHub repository the Suite tracks. Linked to one or more
// AppRegistry rows via AppRepositoryLink (some monorepos serve multiple
// apps). The Suite never stores the GitHub PAT here — that lives in
// env at lib/integrations/github/client.ts. AgentOps capabilities
// receive (repoId, branch, sha) inputs and never the token itself.
model GitRepository {
  id                    String      @id @default(cuid())
  owner                 String
  repo                  String
  fullName              String      @unique // "owner/repo"
  htmlUrl               String?
  defaultBranch         String      @default("main")
  visibility            String? // "public" | "private" | "internal"
  provider              GitProvider @default(github)
  installationId        String? // GitHub App installation id (slice 5+)
  active                Boolean     @default(true)
  // The latest HEAD sha we observed on the default branch — populated
  // by syncRepository(). Drives production_behind_main detection in
  // combination with the deployed sha from /api/build-info.
  latestHeadSha         String?
  latestHeadShortSha    String?
  latestHeadCommittedAt DateTime?
  // Counters refreshed each sync. Cheap to render on the repo table
  // without re-querying every commit row.
  recentCommitCount     Int         @default(0)
  recentWorkflowCount   Int         @default(0)
  lastSyncedAt          DateTime?
  lastSyncError         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appLinks     AppRepositoryLink[]
  commits      GitCommitEvent[]
  workflowRuns GitWorkflowRun[]

  @@index([owner])
  @@index([active])
  @@index([provider])
}

// Many-to-many between AppRegistry and GitRepository. Most apps map
// 1:1 to a repo; monorepos (e.g. WELCOMETOTHETRIBE/CMMC contains
// codex + tooling) need many:many. The link carries deployment hints
// (production branch differs from default, deployment branch differs
// from production, etc.) so production_behind_main can compare the
// right two SHAs.
model AppRepositoryLink {
  id               String   @id @default(cuid())
  appRegistryId    String
  gitRepositoryId  String
  // The branch whose HEAD represents "what should be in production".
  // Defaults to GitRepository.defaultBranch but can be overridden when
  // an app deploys from `release/*` instead of `main`.
  productionBranch String   @default("main")
  // The branch the deployment pipeline pulls from. Same as production
  // for trunk-based shops; different for environments that promote.
  deploymentBranch String   @default("main")
  // The "primary" repo for an app when it has multiple. The Slice 2
  // production-drift evaluator only checks the primary link.
  isPrimary        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  app  AppRegistry   @relation(fields: [appRegistryId], references: [id], onDelete: Cascade)
  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  @@unique([appRegistryId, gitRepositoryId])
  @@index([appRegistryId])
  @@index([gitRepositoryId])
}

// One row per observed commit on a tracked branch. Inserted by both
// the periodic sync (listRecentCommits) and the GitHub push webhook —
// idempotency on (gitRepositoryId, sha) means doubled-up writes are
// no-ops, which is what AgentOps wants when re-running a plan.
model GitCommitEvent {
  id               String    @id @default(cuid())
  gitRepositoryId  String
  sha              String // 40-char SHA-1
  shortSha         String // first 7 chars; denormalised for display
  branch           String?
  authorName       String?
  authorEmail      String?
  authorLogin      String? // GitHub login when available
  message          String // first line + body; trimmed at insert
  htmlUrl          String?
  committedAt      DateTime?
  pushedAt         DateTime?
  filesChanged     Int       @default(0)
  additions        Int       @default(0)
  deletions        Int       @default(0)
  // List of file paths in this commit. Used by the
  // security_sensitive_change evaluator. JSON array of strings.
  changedFilesJson Json?
  // Risk flags the commit triggered (`auth_change`, `database_change`,
  // `security_sensitive_change`, …). JSON array of strings; the
  // evaluator opens OperationalRiskFlag rows from these.
  riskFlagsJson    Json?
  // Raw webhook payload (minus signature headers). Stored for
  // diagnostic + replay; secrets are redacted at write time by
  // lib/audit.ts redactMetadata.
  rawPayloadJson   Json?

  createdAt DateTime @default(now())

  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  // Idempotency. Per AgentOps discipline: re-running the same sync or
  // re-receiving the same webhook MUST NOT create duplicate rows.
  @@unique([gitRepositoryId, sha])
  @@index([gitRepositoryId, committedAt(sort: Desc)])
  @@index([authorEmail])
  @@index([branch])
  @@index([committedAt(sort: Desc)])
}

// One row per GitHub workflow run we've observed. Inserted by both
// the periodic sync (listWorkflowRuns) and the workflow_run webhook;
// idempotency is on githubRunId.
model GitWorkflowRun {
  id              String              @id @default(cuid())
  gitRepositoryId String
  githubRunId     BigInt              @unique
  name            String
  event           String // "push" | "pull_request" | "workflow_dispatch" | …
  branch          String?
  headSha         String
  status          WorkflowStatus      @default(unknown)
  conclusion      WorkflowConclusion?
  htmlUrl         String?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  rawPayloadJson  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repo GitRepository @relation(fields: [gitRepositoryId], references: [id], onDelete: Cascade)

  @@index([gitRepositoryId, startedAt(sort: Desc)])
  @@index([branch])
  @@index([status])
  @@index([conclusion])
}

// ============================================================================
// COMMAND CENTER — Deployment Intelligence (Slice 3)
// ============================================================================

// Mirrors a Railway (project, service, environment) tuple in the Suite's
// DB. Slice 3 syncs each tuple from the Railway GraphQL API every
// reconciliation cycle and on inbound webhook deliveries. The Railway
// API token never lives here — only resolved IDs + display metadata.
//
// Idempotency: unique on `(serviceId, environmentId)` — re-running the
// sync or re-receiving a webhook can't dupe the row.
//
// AgentOps: future capability `trigger_railway_redeploy` reads this row
// to know which serviceId to redeploy; it does not see the API token.
model RailwayResource {
  id                  String    @id @default(cuid())
  appRegistryId       String?
  projectId           String
  projectName         String?
  serviceId           String
  serviceName         String?
  environmentId       String
  environmentName     String?
  publicDomain        String?
  railwayDashboardUrl String?
  // True when the project / service / environment is reachable in
  // Railway right now. Set to false on a 404/410/access-denied response;
  // the row stays so the audit trail and historical DeploymentSnapshots
  // keep their FK target.
  active              Boolean   @default(true)
  lastSyncedAt        DateTime?
  lastSyncError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app                 AppRegistry?         @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)
  deploymentSnapshots DeploymentSnapshot[]

  @@unique([serviceId, environmentId])
  @@index([appRegistryId])
  @@index([projectId])
  @@index([active])
}

// One row per observed Railway deployment. Inserted by the periodic
// sync (listDeployments) and the deployment_status webhook —
// idempotency on `railwayDeploymentId` means doubled-up writes are
// no-ops.
//
// `liveCommitSha` lets the deployment evaluator answer "what commit is
// actually running in production" without making a separate Railway
// API call per app on every reconciliation pass.
model DeploymentSnapshot {
  id                    String                @id @default(cuid())
  appRegistryId         String?
  railwayResourceId     String
  railwayDeploymentId   String                @unique
  railwayStatus         DeploymentStatus      @default(unknown)
  // Raw status string from Railway for forensics (the enum collapses
  // unknown values to `unknown`). Persist the original alongside.
  railwayStatusRaw      String?
  // Health probe outcome at the time of this snapshot. Slice 1's
  // HealthCheckSnapshot is the per-probe time series; this column is
  // the denormalised "what was health when this deploy went out".
  healthStatus          HealthStatus?
  healthStatusRaw       String?
  healthStatusCode      Int?
  healthLatencyMs       Int?
  // Commit info for the deployment. liveCommitSha is the source of
  // truth for production_behind_main detection in slice 3 — we no
  // longer have to read /api/build-info for apps that have been
  // synced from Railway.
  liveCommitSha         String?
  liveCommitShortSha    String?
  liveBranch            String?
  liveRepo              String?
  // GitHub HEAD at the time of the comparison + the diff.
  githubHeadSha         String?
  githubHeadShortSha    String?
  commitsBehind         Int?
  commitsAhead          Int?
  productionDriftStatus DeploymentDriftStatus @default(unknown)
  // Most recent successful deploy — used by the stale_deployment rule.
  lastSuccessfulCheckAt DateTime?
  checkedAt             DateTime              @default(now())
  metadataJson          Json?

  createdAt DateTime @default(now())

  app             AppRegistry?    @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)
  railwayResource RailwayResource @relation(fields: [railwayResourceId], references: [id], onDelete: Cascade)

  @@index([railwayResourceId, checkedAt(sort: Desc)])
  @@index([appRegistryId, checkedAt(sort: Desc)])
  @@index([railwayStatus])
  @@index([productionDriftStatus])
  @@index([checkedAt(sort: Desc)])
}

// ============================================================================
// COMMAND CENTER — Polish + Intelligence (Slice 4)
// ============================================================================

// Daily / weekly / release / deployment / incident / manual narrative
// summaries built from GitCommitEvent rows. Slice 4 ships a
// deterministic generator (group commits by app, surface
// security-sensitive changes, list contributors) and a stub for
// AI-augmented summaries gated behind ENABLE_AI_SUMMARIES.
//
// Idempotency: when a summary covers a (rangeBaseSha, rangeHeadSha,
// summaryType) pair we update the existing row rather than creating a
// new one. The (appRegistryId, summaryType, rangeHeadSha) triple is
// the practical key — operators can re-generate the same summary
// repeatedly without flooding the table.
model CommitSummary {
  id                           String            @id @default(cuid())
  appRegistryId                String?
  // Slice 4 summaries are mostly app-scoped; cross-app rollups carry
  // gitRepositoryId=null. The index supports both queries cleanly.
  gitRepositoryId              String?
  rangeBaseSha                 String?
  rangeHeadSha                 String?
  summaryType                  CommitSummaryType @default(manual)
  // Markdown-ish; rendered as plain text in the UI for now. The
  // executive summary is the elevator pitch (2-3 sentences). The
  // technical summary is the detailed change list. The compliance
  // impact + risk summary are pulled out so an assessor or operator
  // can scan them independently.
  executiveSummary             String
  technicalSummary             String
  complianceImpact             String?
  riskSummary                  String?
  // List of AppRegistry.appKey values this summary is about. Used by
  // /admin/repositories/release-notes for filtering.
  affectedAppsJson             Json?
  // List of GitCommitEvent.id values the security_sensitive_change
  // evaluator flagged in this range. Cross-link target for triage.
  securitySensitiveChangesJson Json?
  // Whether the AI-augmented path produced this summary; null/false
  // means the deterministic path. Stored for audit + so the UI can
  // surface a "generated by AI" hint.
  aiAugmented                  Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app AppRegistry? @relation(fields: [appRegistryId], references: [id], onDelete: SetNull)

  @@index([appRegistryId, summaryType, createdAt(sort: Desc)])
  @@index([summaryType, createdAt(sort: Desc)])
  @@index([rangeHeadSha])
}

// Directed edge in the MacTech ecosystem dependency graph. Source
// app depends on target app via the named relationship. Many-to-many
// because most apps have multiple upstreams; the unique constraint
// on (source, target, type) lets the same pair carry several edges
// of different kinds (capture might be `api_calls` AND `content_source`
// to suite, for example).
model AppDependency {
  id                  String            @id @default(cuid())
  sourceAppRegistryId String
  targetAppRegistryId String
  dependencyType      AppDependencyType @default(other)
  description         String?
  // Inheriting the same enum we use on AppRegistry — when a target
  // app is mission_critical and an edge has criticality=high, the
  // ecosystem graph surfaces the edge with a heavier stroke.
  criticality         AppCriticality    @default(medium)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source AppRegistry @relation("DependencySource", fields: [sourceAppRegistryId], references: [id], onDelete: Cascade)
  target AppRegistry @relation("DependencyTarget", fields: [targetAppRegistryId], references: [id], onDelete: Cascade)

  // Idempotency: same (source, target, type) tuple cannot dupe. Same
  // pair can carry multiple types (e.g. capture → suite via
  // api_calls AND content_source) — they're separate rows.
  @@unique([sourceAppRegistryId, targetAppRegistryId, dependencyType])
  @@index([sourceAppRegistryId])
  @@index([targetAppRegistryId])
  @@index([dependencyType])
}

// ============================================================================
// Slice 6 — Inter-app traffic observability.
// AppDependency captures the DECLARED relationships; AppCallEvent
// captures OBSERVED ones. Each row is a single inbound HTTP call to a
// Suite endpoint, attributed to the calling app via API key (or to a
// non-app source like "github" / "railway" via sourceLabel). Edge
// width on the ecosystem map and the /admin/ops/traffic log both
// aggregate from this table.
// ============================================================================

model AppCallEvent {
  id                  String   @id @default(cuid())
  // Receiver — always one of our AppRegistry rows. Nullable so we
  // can record calls into the suite even before AppRegistry has been
  // seeded for it (rare but defensive).
  targetAppRegistryId String?
  // Caller. Nullable for non-app sources (GitHub webhooks, Railway
  // webhooks, Clerk webhooks); see sourceLabel for the canonical
  // string identity in those cases.
  sourceAppRegistryId String?
  // Canonical caller label. For app-to-app traffic this matches the
  // source's appKey. For external sources it's "github" / "railway"
  // / "clerk" / "anonymous". Indexed for filterability.
  sourceLabel         String
  // Slice 6.1: canonical target label, mirror of sourceLabel. For
  // inbound traffic to Suite this is "identity-command-center" (the
  // default — the Slice 6 release captured Suite-bound calls only).
  // For outbound calls Suite makes, this is "github" / "railway" /
  // "openai" / etc. so the traffic graph and the per-target filter
  // can attribute symmetrically.
  targetLabel         String   @default("identity-command-center")
  // The HTTP path that received the call (already redacted of any
  // dynamic ids; we store the route pattern, not the literal URL).
  endpoint            String
  method              String
  statusCode          Int
  bytesIn             Int      @default(0)
  bytesOut            Int      @default(0)
  durationMs          Int?
  // ApiKey id when the call authenticated with a DB-issued key —
  // nullable for cron / webhook / unauthenticated calls.
  apiKeyId            String?
  // The request id we generated server-side, useful for joining to
  // AuditLog / SecurityEvent for the same call.
  requestId           String?
  // Free-form structured metadata redacted by lib/audit. Kept small
  // — large payloads belong on AuditLog.
  metadataJson        Json?

  occurredAt          DateTime @default(now())

  source AppRegistry? @relation("CallEventSource", fields: [sourceAppRegistryId], references: [id], onDelete: SetNull)
  target AppRegistry? @relation("CallEventTarget", fields: [targetAppRegistryId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([targetAppRegistryId, occurredAt(sort: Desc)])
  @@index([sourceAppRegistryId, occurredAt(sort: Desc)])
  @@index([sourceLabel, occurredAt(sort: Desc)])
  @@index([targetLabel, occurredAt(sort: Desc)])
  @@index([endpoint])
  @@index([statusCode])
}

// ============================================================================
// AgentOps (Slice 5) — natural-language → plan → human approval → execute.
// The capability registry itself is code-defined (lib/agents/capabilities)
// and not stored in the DB; that prevents "approved" capabilities from
// being widened by an unauthorized row insert. The DB only persists runs,
// the steps the planner produced, the artifacts they emitted, and the
// approval/rejection events.
// ============================================================================

enum AgentRunStatus {
  planned
  awaiting_approval
  approved
  rejected
  running
  completed
  failed
  cancelled
  // IBE gate (Slice 5.5): every step ran, but at least one declared
  // invariant did not hold. Distinct from `failed` (which means a step
  // threw); a `refused` run executed cleanly but did not satisfy the
  // user's declared intent contract.
  refused
}

enum AgentRiskTolerance {
  // Any invariant violation refuses the run. Default for bulk actions.
  strict
  // Only NEW violations (vs. baseline state) refuse. v1 still treats
  // moderate as "any violation" pending baseline-snapshot wiring.
  moderate
  // Invariants are evaluated + recorded but never refuse the run.
  permissive
}

enum AgentStepStatus {
  planned
  skipped
  running
  succeeded
  failed
}

enum AgentStepKind {
  read_only
  approval_required
}

enum AgentApprovalDecision {
  approved
  rejected
}

enum AgentArtifactKind {
  release_notes
  draft_pr_description
  github_issue_body
  audit_summary
  risk_summary
  deployment_drift_summary
  app_status_summary
  health_summary
  raw_json
  markdown
}

model AgentRun {
  id                String         @id @default(cuid())
  status            AgentRunStatus @default(planned)
  // Free-text request the user typed. Kept for audit; never re-fed to
  // the LLM after planning.
  requestText       String         @db.Text
  // Verbatim plan-summary the planner produced — explains, in plain
  // English, what the plan does. Helps the approver understand intent.
  planSummary       String?        @db.Text
  // Whether the planner ran in deterministic mode (no LLM) because
  // OPENAI_API_KEY/ENABLE_AI_PLANNER weren't configured.
  deterministicPlan Boolean        @default(false)
  // Total step count at plan-time (before execution). Used by the UI
  // without joining steps.
  plannedStepCount  Int            @default(0)
  // True if the plan contains at least one approval_required step.
  requiresApproval  Boolean        @default(false)

  requestedByClerkUserId  String
  requestedByEmail        String
  // Approver identity — populated when an approval row lands. Enforced
  // at the service layer to be different from requestedByClerkUserId
  // (separation of duties).
  approvedByClerkUserId   String?
  approvedByEmail         String?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  rejectionReason         String?

  startedAt   DateTime?
  completedAt DateTime?
  failureReason String?

  // ── Slice 5.5: IBE Gates ─────────────────────────────────────────────
  // The user-declared Intent the run must satisfy. Stored verbatim so
  // assessors can replay both the request and the contract it carried.
  // Validation rules are ported from /Users/patrick/IBE/src/intent.
  intentGoal           String?              @db.Text
  intentRiskTolerance  AgentRiskTolerance   @default(strict)
  // Resource-scope: which apps/repos this call is allowed to touch.
  // Empty array == unbounded (legacy runs and read-only fan-outs).
  // Stored as String[] (Postgres text[]) so we can index later if
  // needed; the orchestrator validates each step's input against
  // these arrays before execution.
  intentScopeAppIds    String[]             @default([])
  intentScopeRepoIds   String[]             @default([])
  // User-selected invariant keys grouped by capability:
  //   { "<capabilityKey>": ["<invariantKey>", ...], ... }
  // The orchestrator only enforces invariants the user explicitly
  // checked — nothing implicit, nothing surprising.
  intentInvariantsJson Json?
  // Validation outcome for the goal text + scope + invariants. Captured
  // even on accepted runs so an admin can audit the validator's pass
  // history. Shape: { errors: ValidationError[], passed: boolean }.
  intentValidationJson Json?
  // Refusal explanation when status=refused. Lists which invariants
  // failed on which steps so the operator can act.
  refusalReason        String?              @db.Text

  // ── Slice 5.7: External (Claude / automation) trigger source ──────
  // When the run was created via the M2M /api/v1/agents/runs endpoint
  // instead of a browser session, this carries the ApiKey id that
  // authenticated the call. Browser-initiated runs leave it null.
  triggeredByApiKeyId  String?
  triggeredByApiKeyName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps      AgentStep[]
  artifacts  AgentArtifact[]
  approvals  AgentApproval[]

  @@index([status])
  @@index([requestedByClerkUserId])
  @@index([createdAt])
  @@index([status, createdAt])
}

model AgentStep {
  id              String          @id @default(cuid())
  agentRunId      String
  // Order in the plan (1-indexed). Plans execute sequentially in this
  // order; a failure aborts the run.
  stepIndex       Int
  capabilityKey   String          // e.g. "summarize_open_risks"
  capabilityVersion Int           @default(1)
  kind            AgentStepKind
  status          AgentStepStatus @default(planned)
  // The planner's natural-language description of why this step is in
  // the plan. Surfaced in the approval UI.
  rationale       String?         @db.Text
  // Inputs the planner bound to this step (resource IDs, filters, etc.).
  // Validated against the capability's input schema at execution time.
  inputJson       Json
  // Output of the capability invocation. Truncated to a small JSON
  // summary; large blobs go to AgentArtifact.
  outputJson      Json?
  // AuditLog id for the capability invocation (kept here to make the
  // step row independently usable for assessor replay).
  auditLogId      String?
  // Raw error message on failure, redacted. Stored for assessor replay.
  errorMessage    String?         @db.Text
  durationMs      Int?

  // ── Slice 5.5: IBE invariant results ───────────────────────────────
  // List of { key, ok, actual, message } objects — one per invariant
  // the user requested for this step's capability. Recorded on every
  // step so a `refused` run is post-mortem-able without re-running.
  invariantResultsJson Json?
  // True when at least one declared invariant on this step did not
  // hold (regardless of run-level risk_tolerance).
  invariantViolations  Boolean    @default(false)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  // Idempotency: a single (run, stepIndex) tuple cannot dupe — re-running
  // execute on the same run never doubles up steps, even on transient
  // failure. Replay is "find existing row, advance its status".
  @@unique([agentRunId, stepIndex])
  @@index([agentRunId])
  @@index([capabilityKey])
  @@index([status])
}

model AgentArtifact {
  id            String            @id @default(cuid())
  agentRunId    String
  agentStepId   String?
  kind          AgentArtifactKind
  title         String
  // Stored as Text — release-notes / draft PR descriptions can be long.
  // Never contains secrets — the redactor is applied before write.
  bodyMarkdown  String            @db.Text
  // Optional structured payload (JSON). Used when the artifact is a
  // structured summary the UI renders directly.
  payloadJson   Json?

  createdAt DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId])
  @@index([kind])
}

// ─── Slice 5.8: scheduled triggers ────────────────────────────────────────
// A saved Intent + cron expression that fires on schedule. The cron tick
// endpoint resolves due triggers and drives the same external-trigger
// service the M2M endpoint uses (slice 5.7), so the safety story is
// unchanged: IBE goal/scope/invariant validation, refusal-by-default,
// approval gate for write capabilities, synthetic requester identity
// (`cron:<triggerId>`) that cannot collide with a Clerk admin id.
model AgentTrigger {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  enabled        Boolean  @default(true)
  // Standard 5- or 6-field cron expression (parsed by cron-parser).
  // Validated at create/update time; stored verbatim so an operator
  // can edit it without round-tripping through a parser.
  cronExpression String
  // IANA timezone name; defaults to UTC so cron evaluates deterministically.
  timezone       String   @default("UTC")
  // The Intent + free-text request that fires on each tick. Identical
  // shape to the M2M /api/v1/agents/runs body so a trigger is just a
  // saved M2M call.
  request        String   @db.Text
  intentJson     Json
  autoExecute    Boolean  @default(true)

  // Scheduling state, advanced by the cron tick handler.
  lastFiredAt    DateTime?
  nextFireAt     DateTime?
  // Most-recent fire outcome, kept to surface in the management UI
  // without joining AgentRun.
  lastRunId      String?
  lastRunStatus  AgentRunStatus?
  // Sequential failure count surfaced in the UI to flag stuck triggers.
  consecutiveFailures Int @default(0)

  createdByClerkUserId String
  createdByEmail       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([nextFireAt])
  @@index([createdByClerkUserId])
}

model AgentApproval {
  id           String                @id @default(cuid())
  agentRunId   String
  decision     AgentApprovalDecision
  approverClerkUserId String
  approverEmail       String
  // Optional scope reduction — JSON describing which step indexes were
  // dropped from the plan before approval. Empty {} = full plan approved.
  scopeReductionJson  Json?
  notes        String?              @db.Text

  createdAt DateTime @default(now())

  agentRun AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId])
  @@index([approverClerkUserId])
  @@index([decision])
}
