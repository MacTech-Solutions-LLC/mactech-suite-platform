// MacTech Identity Command Center — Prisma schema.
// Mixes the original tenancy primitives (Tenant / User / Membership /
// AuditEvent / Project / Document) with the command-center models
// (UserProfile, CustomerOrganization, AppRegistry, ProductEntitlement,
// OrgUserAccess, AuditLog, SecurityEvent, RoleTemplate). Existing tables
// remain so legacy callers keep working.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// LEGACY TENANCY (kept; consumed by lib/auth/adapter.ts + lib/db/withTenant.ts)
// ============================================================================

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Tenant {
  id         String   @id @default(cuid())
  externalId String?  @unique
  name       String
  slug       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]
  contracts   Contract[]

  @@index([externalId])
  @@index([slug])
  @@index([isActive])
}

model User {
  id         String   @id @default(cuid())
  externalId String   @unique
  email      String   @unique
  name       String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  auditEvents AuditEvent[]

  contractsCreated           Contract[]               @relation("ContractCreatedBy")
  contractMemberships        ContractMembership[]     @relation("ContractMembershipUser")
  grantedContractMemberships ContractMembership[]     @relation("ContractMembershipGrantedBy")
  contractLifecycleEvents    ContractLifecycleEvent[] @relation("ContractLifecycleEventActor")

  @@index([externalId])
  @@index([email])
  @@index([isActive])
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(VIEWER)
  isActive  Boolean        @default(true)
  joinedAt  DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model Project {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  status      String   @default("draft")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  title     String
  content   String?
  status    String   @default("draft")
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

