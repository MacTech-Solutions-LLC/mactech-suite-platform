# ─────────────────────────────────────────────────────────────────────────────
# MacTech Identity Command Center — environment template
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://mactech_dev:mactech_dev_pass@localhost:5432/mactech_local"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Clerk — required to sign in
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Clerk — webhook signing secret (Settings → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=""

# Audit ingestion — set a strong random value, share with sibling apps
AUDIT_INGEST_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Auditor IP-allowlist portal (/auditor-access) → vault admin endpoint
# ─────────────────────────────────────────────────────────────────────────────
# Base URL for the EnclaveWatch _admin endpoint on the customer's vault
# host. Empty = portal is read-only (form will fail-closed with
# "vault edge unreachable").
VAULT_ADMIN_BASE_URL=""
# 32-byte hex shared with /etc/enclavewatch/vault-admin.secret on the
# vault. ICC HMACs every grant/revoke/list call with this secret.
VAULT_ADMIN_HMAC_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# MacTech Command Center
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret protecting POST /api/command-center/sync when called by cron.
# Generate with: openssl rand -hex 32
COMMAND_CENTER_CRON_SECRET=""

# Per-probe HTTP timeout (milliseconds) for /api/health + /api/build-info
HEALTH_CHECK_TIMEOUT_MS="5000"
HEALTH_CHECK_USER_AGENT="MacTechCommandCenter/1.0"
ENABLE_HEALTH_CHECKS="true"

# Slice 2/3 — leave false until those PRs land.
ENABLE_GITHUB_SYNC="false"
ENABLE_RAILWAY_SYNC="false"
ENABLE_AI_SUMMARIES="false"

# Optional integration credentials. Slice 1 doesn't read these; they're
# documented here so the contract is set across PRs.
GITHUB_TOKEN=""
GITHUB_WEBHOOK_SECRET=""
RAILWAY_API_TOKEN=""
RAILWAY_WEBHOOK_SECRET=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
OPENAI_API_KEY=""

# MacTech AI / NVIDIA NIM (external inference is separately opt-in)
AI_ENABLED="false"
AI_PROVIDER="mock"
AI_EXTERNAL_INFERENCE_ENABLED="false"
AI_DEVELOPMENT_MODE="false"
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_CHAT_MODEL=""
NVIDIA_EMBEDDING_MODEL=""
AI_MAX_INPUT_CHARS="16000"
AI_MAX_OUTPUT_TOKENS="1200"
AI_REQUEST_TIMEOUT_MS="30000"
AI_ALLOWED_CLASSIFICATIONS="PUBLIC,INTERNAL"
AI_STORE_CONVERSATION_CONTENT="false"
AI_AUDIT_RETENTION_DAYS="365"
AI_MAX_RETRIEVAL_CHUNKS="5"
OPPORTUNITIES_BASE_URL="http://localhost:3001"
PROPOSAL_BASE_URL="http://localhost:3002"

# ─────────────────────────────────────────────────────────────────────────────
# QuickBooks Online (commerce + recurring billing)
# ─────────────────────────────────────────────────────────────────────────────
# Created in https://developer.intuit.com -> My Apps -> Keys & OAuth.
# Use sandbox creds while QBO_ENV="sandbox"; switch both at once when
# promoting to production.
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
# Must match the redirect URI registered on the Intuit app exactly.
QBO_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"
# Webhooks tab on the Intuit app. Used to verify X-Intuit-Signature HMAC.
QBO_WEBHOOK_VERIFIER_TOKEN=""
# "sandbox" or "production".
QBO_ENV="sandbox"
# 32-byte key for AES-256-GCM encryption of stored OAuth tokens.
# Generate with: openssl rand -base64 32
QBO_ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Commercial Operations (marketing-site → Hub → QBO → provisioning)
# ─────────────────────────────────────────────────────────────────────────────
# Shared HMAC secret the public marketing site uses to sign POSTs to
# /api/checkout/sessions and /api/public/intake. Header is
# X-Mactech-Signature: sha256=<hex>. Generate with: openssl rand -hex 32
MARKETING_SITE_HMAC_SECRET=""
# Clerk user ID of the service account that gets attributed as the creator
# of auto-provisioned Clerk orgs and the inviter on customer invitations.
# Typically a MacTech super admin's clerkUserId.
SYSTEM_PROVISIONER_CLERK_USER_ID=""

# Shared secret for the public feedback-ingest route (POST /api/public/feedback).
# The UI-Fix Chrome extension sends it as `Authorization: Bearer <secret>`.
# Set the same value here and in each teammate's extension Options page.
# Generate with: openssl rand -hex 32
FEEDBACK_INGEST_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Seed bootstraps (optional)
# ─────────────────────────────────────────────────────────────────────────────

# To grant yourself MacTech Super Admin on first seed:
SEED_SUPER_ADMIN_EMAIL=""
SEED_SUPER_ADMIN_CLERK_USER_ID=""

# Legacy bootstrap tenant (kept for /api/tenant compatibility)
SEED_TENANT_EXTERNAL_ID="tenant_bootstrap_001"
SEED_DEVELOPER_EXTERNAL_ID=""
SEED_DEVELOPER_EMAIL=""
SEED_DEVELOPER_NAME=""
