# ─────────────────────────────────────────────────────────────────────────────
# MacTech Identity Command Center — environment template
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://mactech_dev:mactech_dev_pass@localhost:5432/mactech_local"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Clerk — required to sign in
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Clerk — webhook signing secret (Settings → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=""

# Audit ingestion — set a strong random value, share with sibling apps
AUDIT_INGEST_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Auditor IP-allowlist portal (/auditor-access) → vault admin endpoint
# ─────────────────────────────────────────────────────────────────────────────
# Base URL for the EnclaveWatch _admin endpoint on the customer's vault
# host. Empty = portal is read-only (form will fail-closed with
# "vault edge unreachable").
VAULT_ADMIN_BASE_URL=""
# 32-byte hex shared with /etc/enclavewatch/vault-admin.secret on the
# vault. ICC HMACs every grant/revoke/list call with this secret.
VAULT_ADMIN_HMAC_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Seed bootstraps (optional)
# ─────────────────────────────────────────────────────────────────────────────

# To grant yourself MacTech Super Admin on first seed:
SEED_SUPER_ADMIN_EMAIL=""
SEED_SUPER_ADMIN_CLERK_USER_ID=""

# Legacy bootstrap tenant (kept for /api/tenant compatibility)
SEED_TENANT_EXTERNAL_ID="tenant_bootstrap_001"
SEED_DEVELOPER_EXTERNAL_ID=""
SEED_DEVELOPER_EMAIL=""
SEED_DEVELOPER_NAME=""
