# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Docker Local Development (MT-019)
# Matches docker-compose.yml credentials
DATABASE_URL="postgresql://mactech_dev:mactech_dev_pass@localhost:5432/mactech_local"

# Production/Hosted Alternative (uncomment when ready)
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_<YOUR_CLERK_PUBLISHABLE_KEY>"
CLERK_SECRET_KEY="sk_test_<YOUR_CLERK_SECRET_KEY>"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Google Workspace SSO (if using Clerk enterprise connection)
# These are configured in Clerk Dashboard, not directly in app
# CLERK_GOOGLE_CLIENT_ID="<CONFIGURED_IN_CLERK_DASHBOARD>"
# CLERK_GOOGLE_CLIENT_SECRET="<CONFIGURED_IN_CLERK_DASHBOARD>"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Security
# Generate strong random values for production
# SESSION_SECRET="<GENERATE_STRONG_RANDOM_32_CHAR_MIN>"

# Audit & Compliance
# AUDIT_LOG_LEVEL="info"
# AUDIT_RETENTION_DAYS="90"

# Seed Configuration (MT-019)
# REQUIRED for local seeding: Set in .env.local (never committed)
# Get these from Clerk Dashboard -> Users / Organizations
# SEED_DEVELOPER_EXTERNAL_ID=
# SEED_TENANT_EXTERNAL_ID=
# SEED_DEVELOPER_EMAIL=
# SEED_DEVELOPER_NAME=
# Set these to auto-populate your developer identity in local seed
# SEED_DEVELOPER_EXTERNAL_ID="user_xxxxx_or_google_sub"
# SEED_DEVELOPER_EMAIL="your@email.com"
# SEED_DEVELOPER_NAME="Your Name"
# SEED_TENANT_EXTERNAL_ID="tenant_bootstrap_001"
